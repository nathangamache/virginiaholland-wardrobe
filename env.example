# --- App ---
NODE_ENV=production
APP_URL=https://wardrobe.virginiaholland.art
# Absolute path on the Ubuntu server where the app lives.
# Images will be stored at $APP_ROOT/storage/images/...
APP_ROOT=/home/virginiaholland-wardrobe/htdocs/wardrobe.virginiaholland.art

# --- Database ---
DATABASE_URL=postgres://wardrobe:changeme@localhost:5432/wardrobe

# --- Auth ---
# Long random string. Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-long-random-string
# Session lifetime in days
SESSION_DAYS=90
# Domain for the session cookie (leave as APP_URL host)
COOKIE_DOMAIN=wardrobe.virginiaholland.art

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
# Must be a verified sender on Resend
EMAIL_FROM="Wardrobe <no-reply@virginiaholland.art>"

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxx

# Two-model setup:
#   FAST  = image tagging on upload + wishlist gap analysis
#   SMART = outfit ranking + packing plans (aesthetic + multi-day reasoning)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# Optional per-task overrides (leave commented to use FAST/SMART above):
# ANTHROPIC_MODEL_TAG=claude-haiku-4-5
# ANTHROPIC_MODEL_WISHLIST=claude-haiku-4-5
# ANTHROPIC_MODEL_RANK=claude-sonnet-4-6
# ANTHROPIC_MODEL_PACKING=claude-opus-4-7

# --- Weather ---
# Open-Meteo needs no key. Default home location for weather fetches.
# 11773 Beacon Hill Dr, Plymouth, MI 48170
DEFAULT_LATITUDE=42.36669326272332
DEFAULT_LONGITUDE=-83.4927024486844
DEFAULT_TIMEZONE=America/Detroit
